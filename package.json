{
  "name": "istanbul-parking-heatmap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-parks": "python3 scripts/fetch_park_locations.py",
    "scrape": "python3 scripts/scrape_ispark.py",
    "aggregate": "python3 scripts/aggregate_ispark.py",
    "mock-data": "python3 scripts/generate_mock_profiles.py",
    "pipeline": "python3 scripts/fetch_park_locations.py && python3 scripts/generate_mock_profiles.py",
    "pipeline-real": "python3 scripts/fetch_park_locations.py && python3 scripts/aggregate_ispark.py"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "deck.gl": "^9.2.11",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2"
  }
}
